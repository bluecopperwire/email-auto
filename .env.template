# ==============================================================================
# Gmail SMTP Credentials
# ==============================================================================
# Your personal Gmail address.
GMAIL_ADDRESS=your.email@gmail.com

# Your 16-character Gmail App Password (NOT your login password).
# See README.md for instructions on how to generate this app password.
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ==============================================================================
# SMTP Connection Settings
# ==============================================================================
# Default is smtp.gmail.com.
SMTP_SERVER=smtp.gmail.com

# Port 465 is for SSL (recommended). Port 587 is for STARTTLS.
SMTP_PORT=465

# ==============================================================================
# File Paths
# ==============================================================================
# Path to the CSV input file containing target companies and email addresses.
# You can set this to:
# "(APPLY via PUPInternlink) CCIS Host Training Establishment Updated 2026-2021.csv"
# or
# "(APPLY via PUPInternlink) CCIS Host Training Establishment Updated 2026-2021 2.csv"
CSV_FILE_PATH=(APPLY via PUPInternlink) CCIS Host Training Establishment Updated 2026-2021.csv

# Path to your resume PDF. The default is to load from the attachments folder.
RESUME_PATH=attachments/Resume.pdf

# ==============================================================================
# Delay Settings (in seconds)
# ==============================================================================
# Wait a random duration between MIN_DELAY and MAX_DELAY before sending each email.
MIN_DELAY=10
MAX_DELAY=20

# ==============================================================================
# Execution Mode
# ==============================================================================
# Set DRY_RUN to True to run the script without sending any emails.
# In DRY_RUN mode, the script parses the CSV, validates emails, checks for
# duplicates, simulates delays, and outputs dry-run log details.
# Change to False to actually send emails.
DRY_RUN=True

# ==============================================================================
# Blacklist Settings
# ==============================================================================
# Path to a text file containing blacklisted companies or email addresses (one per line).
BLACKLIST_FILE_PATH=blacklist.txt
